<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stunde 2 – Normenanalyse üben &amp; Wissen sichern</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --blue-900:#0D47A1;--blue-800:#1565C0;--blue-700:#1976D2;--blue-400:#29B6F6;--blue-50:#E3F2FD;
  --green:#43A047;--green-light:#E8F5E9;
  --orange:#FF9800;--orange-light:#FFF3E0;
  --purple:#AB47BC;--purple-light:#F3E5F5;
  --red:#E53935;--red-light:#FFEBEE;
  --text:#1A1A1A;--text-secondary:#555555;--text-muted:#AAAAAA;
  --border:#E0E0E0;--bg-card:#FFFFFF;--bg-page:#F0F4F8;
  --grad-blue:linear-gradient(135deg,#1976D2,#29B6F6);
  --grad-green:linear-gradient(135deg,#43A047,#26C6DA);
  --grad-orange:linear-gradient(135deg,#FF9800,#F44336);
  --radius-sm:8px;--radius-md:12px;--radius-lg:16px;
  --shadow:0 2px 8px rgba(0,0,0,0.08);--shadow-lg:0 4px 20px rgba(0,0,0,0.12);
  /* Aliases */
  --indigo:var(--blue-700);--indigo-light:var(--blue-400);--indigo-xlight:var(--blue-50);
  --teal:#0d9488;--teal-light:#ccfbf1;
  --amber:var(--orange);--amber-light:var(--orange-light);
  --rose:var(--red);--rose-light:var(--red-light);
  --slate:var(--text);--slate-mid:var(--text-secondary);--slate-light:var(--text-muted);
  --bg:var(--bg-page);--success:var(--green);--success-light:var(--green-light);
  --radius:var(--radius-lg);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Nunito',sans-serif;background:var(--bg-page);color:var(--text);font-size:16px;line-height:1.7;}

/* TOPBAR */
.topbar{background:var(--blue-700);color:white;padding:0 2rem;display:flex;align-items:center;gap:1rem;height:52px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(25,118,210,0.25);}
.topbar-logo{font-family:'Nunito',sans-serif;font-weight:900;font-size:15px;color:white;text-decoration:none;}
.topbar-logo span{color:var(--blue-400);}
.topbar-sep{width:1px;height:20px;background:rgba(255,255,255,0.2);}
.topbar-title{font-size:13px;color:var(--blue-50);font-weight:400;}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.mode-toggle{display:flex;background:rgba(255,255,255,0.12);border-radius:100px;padding:3px;gap:2px;}
.mode-btn{border:none;background:transparent;color:rgba(255,255,255,0.7);font-family:'Nunito',sans-serif;font-size:12px;font-weight:600;padding:5px 14px;border-radius:100px;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.mode-btn.active{background:white;color:var(--blue-700);font-weight:700;}

/* PROGRESS */
.progress-bar-wrap{background:white;border-bottom:1px solid var(--border);padding:0 2rem;}
.progress-inner{max-width:880px;margin:0 auto;display:flex;align-items:center;gap:6px;padding:10px 0;}
.prog-step{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted);cursor:pointer;transition:color 0.2s;font-family:'Nunito',sans-serif;}
.prog-step.active{color:var(--blue-700);font-weight:700;}
.prog-step.done{color:var(--green);}
.prog-dot{width:22px;height:22px;border-radius:50%;background:var(--border);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--text-muted);flex-shrink:0;transition:all 0.2s;}
.prog-step.active .prog-dot{background:var(--blue-700);color:white;}
.prog-step.done .prog-dot{background:var(--green);color:white;}
.prog-line{flex:1;height:2px;background:var(--border);min-width:8px;border-radius:2px;}
.prog-line.done{background:var(--green);}

/* MAIN */
.main{max-width:880px;margin:0 auto;padding:2rem 2rem 6rem;}

/* HERO */
.hero{background:var(--grad-blue);border-radius:var(--radius-lg);padding:2.5rem 2.5rem 2rem;color:white;margin-bottom:1.5rem;position:relative;overflow:hidden;}
.hero::before{content:'§';position:absolute;right:1.5rem;top:-10px;font-family:'Nunito',sans-serif;font-size:130px;font-weight:900;color:rgba(255,255,255,0.06);line-height:1;pointer-events:none;}
.hero-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.18);border-radius:100px;padding:4px 14px;font-size:12px;font-weight:700;margin-bottom:1rem;}
.hero h1{font-family:'Nunito',sans-serif;font-size:27px;font-weight:900;line-height:1.2;margin-bottom:0.75rem;}
.hero p{font-size:15px;color:rgba(255,255,255,0.88);max-width:580px;line-height:1.6;margin-bottom:1.25rem;}
.hero-meta{display:flex;gap:16px;font-size:13px;color:rgba(255,255,255,0.72);flex-wrap:wrap;}
.hero-meta-item{display:flex;align-items:center;gap:5px;}

/* TEACHER NOTE */
.teacher-note{background:#fffbeb;border:1.5px solid #fbbf24;border-radius:var(--radius-md);padding:1.25rem 1.5rem;margin-bottom:1.5rem;display:none;}
.teacher-note-header{display:flex;align-items:center;gap:8px;font-family:'Nunito',sans-serif;font-weight:800;font-size:13px;color:#92400e;margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.5px;}
.teacher-note p{font-size:14px;color:#78350f;line-height:1.6;}
.teacher-note ul{font-size:14px;color:#78350f;padding-left:1.2rem;line-height:1.8;margin-top:0.4rem;}

/* SECTION */
.section{background:white;border-radius:var(--radius-lg);border:1px solid var(--border);margin-bottom:1.25rem;overflow:hidden;box-shadow:var(--shadow);animation:fadeUp 0.3s ease both;}
.section-header{padding:1.25rem 1.5rem 1rem;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:12px;}
.section-icon{width:38px;height:38px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0;margin-top:1px;}
.section-icon.blue{background:var(--blue-50);}
.section-icon.green{background:var(--green-light);}
.section-icon.orange{background:var(--orange-light);}
.section-icon.red{background:var(--red-light);}
.section-icon.purple{background:var(--purple-light);}
.section-icon.teal{background:#ccfbf1;}
.section-meta{flex:1;}
.section-tag{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--text-muted);margin-bottom:3px;}
.section-title{font-family:'Nunito',sans-serif;font-size:17px;font-weight:800;color:var(--text);line-height:1.3;}
.section-time{font-size:12px;color:var(--text-muted);margin-top:3px;}
.section-body{padding:1.5rem;}

/* PARA LINKS */
a.para-link{color:var(--blue-700);text-decoration:none;border-bottom:1px dotted var(--blue-700);font-weight:700;transition:color 0.15s;}
a.para-link:hover{color:var(--blue-400);}

/* PARAGRAPH QUOTE BOX – dark bg, always light text */
.para-quote{background:#1e293b;border-radius:var(--radius-md);padding:1.25rem 1.5rem;margin:0.75rem 0;}
.para-quote .para-label{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:#94a3b8;margin-bottom:0.6rem;font-weight:700;}
.para-quote p,.task-body .para-quote p,.section-body .para-quote p{font-size:15px !important;line-height:1.7 !important;color:#e2e8f0 !important;font-style:italic !important;margin-bottom:0 !important;}
.para-quote .para-ref,.task-body .para-quote .para-ref{font-size:12px !important;color:#64748b !important;margin-top:0.6rem;font-style:normal !important;}
.para-quote a{color:var(--blue-400) !important;border-bottom-color:var(--blue-400) !important;}

/* BOOK REF */
.book-ref{background:#faf5ff;border:1.5px solid #d8b4fe;border-radius:var(--radius-md);padding:1.1rem 1.25rem;margin:1rem 0;display:flex;gap:12px;align-items:flex-start;}
.book-ref-icon{font-size:24px;flex-shrink:0;}
.book-ref-body{flex:1;}
.book-ref-title{font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:#6b21a8;margin-bottom:4px;}
.book-ref-text{font-size:14px;color:#581c87;line-height:1.6;}
.book-ref-text strong{font-weight:700;}

/* CONTENT */
.content-text{font-size:15px;color:var(--text-secondary);line-height:1.75;margin-bottom:1rem;}
.info-box{border-radius:var(--radius-md);padding:1.1rem 1.25rem;margin:1rem 0;font-size:14px;line-height:1.65;}
.info-box.blue{background:var(--blue-50);border-left:3px solid var(--blue-700);color:var(--blue-800);}
.info-box.teal{background:#ccfbf1;border-left:3px solid #0d9488;color:#134e4a;}
.info-box.orange{background:var(--orange-light);border-left:3px solid var(--orange);color:#78350f;}
.info-box.green{background:var(--green-light);border-left:3px solid var(--green);color:#1b5e20;}
.info-box strong{font-weight:700;display:block;margin-bottom:4px;}

/* CHIPS */
.chip-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1rem;}
.chip{font-size:11px;padding:3px 10px;border-radius:100px;font-weight:700;border:1px solid;}
.chip.k{background:var(--blue-50);border-color:var(--blue-400);color:var(--blue-700);}
.chip.c1{background:#e0f2fe;border-color:#bae6fd;color:#0369a1;}
.chip.c2{background:#ccfbf1;border-color:#99f6e4;color:#0f766e;}
.chip.c3{background:var(--orange-light);border-color:#fde68a;color:#92400e;}
.chip.c4{background:var(--purple-light);border-color:#d8b4fe;color:#6b21a8;}

/* TASK */
.task{border:1.5px solid var(--blue-400);border-radius:var(--radius-md);overflow:hidden;margin:1rem 0;}
.task-header{background:var(--blue-700);padding:0.75rem 1.1rem;display:flex;align-items:center;gap:10px;}
.task-num{width:24px;height:24px;border-radius:50%;background:rgba(255,255,255,0.2);color:white;font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.task-title{font-size:13px;font-weight:700;color:white;}
.task-body{padding:1.1rem 1.2rem;background:#F0F4F8;}
.task-body p{font-size:14px;color:var(--text);line-height:1.65;margin-bottom:0.5rem;}
.task-body p:last-child{margin-bottom:0;}

/* NORMEN TABLE */
.normen-exercise{background:#f8fafc;border:1.5px solid var(--border);border-radius:var(--radius-md);padding:1.25rem;margin:1rem 0;}
.normen-exercise h4{font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;margin-bottom:0.75rem;color:var(--text);}
.normen-table{width:100%;border-collapse:collapse;font-size:13px;}
.normen-table th{background:var(--blue-700);color:white;padding:8px 12px;text-align:left;font-weight:700;font-size:12px;}
.normen-table th:first-child{border-radius:8px 0 0 0;}
.normen-table th:last-child{border-radius:0 8px 0 0;}
.normen-table td{padding:8px 12px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:top;line-height:1.5;}
.normen-table tr:last-child td{border-bottom:none;}
.normen-table tr:nth-child(even) td{background:#f8fafc;}
.normen-table input[type="text"]{width:100%;border:1.5px solid var(--border);border-radius:6px;padding:5px 8px;font-family:'Nunito',sans-serif;font-size:13px;background:white;}
.normen-table input[type="text"]:focus{outline:none;border-color:var(--blue-700);}

/* ANSWER AREA */
.answer-area{width:100%;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'Nunito',sans-serif;font-size:14px;color:var(--text);resize:vertical;min-height:80px;margin-top:8px;background:white;transition:border-color 0.15s;}
.answer-area:focus{outline:none;border-color:var(--blue-700);}

/* SOLUTION BTN */
.solution-btn{display:inline-flex;align-items:center;gap:6px;margin-top:10px;padding:8px 16px;border:1.5px solid var(--border);background:white;border-radius:var(--radius-sm);font-family:'Nunito',sans-serif;font-size:13px;font-weight:600;color:var(--text-secondary);cursor:pointer;transition:all 0.15s;}
.solution-btn:hover{border-color:var(--blue-700);color:var(--blue-700);background:var(--blue-50);}
.solution-reveal{margin-top:10px;background:var(--green-light);border-left:3px solid var(--green);border-radius:0 8px 8px 0;padding:10px 14px;font-size:13px;color:#1b5e20;line-height:1.6;display:none;}
.solution-reveal.visible{display:block;}

/* NORMEN DIAGRAM */
.normen-diagram{display:flex;align-items:stretch;border-radius:var(--radius-md);overflow:hidden;border:1.5px solid var(--border);margin:1rem 0;}
.normen-col{flex:1;padding:1.1rem 1.2rem;}
.normen-col.left{background:var(--blue-50);}
.normen-col.mid{flex:0 0 60px;display:flex;align-items:center;justify-content:center;background:var(--blue-700);font-size:22px;color:white;}
.normen-col.right{background:var(--green-light);}
.normen-col-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.5rem;}
.normen-col.left .normen-col-label{color:var(--blue-700);}
.normen-col.right .normen-col-label{color:var(--green);}
.normen-item{font-size:13px;padding:5px 0;border-bottom:1px dashed rgba(0,0,0,0.08);color:var(--text);line-height:1.4;}
.normen-item:last-child{border-bottom:none;}

/* KI BOX */
.ki-box{background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1.5px solid #86efac;border-radius:var(--radius-md);padding:1.1rem 1.25rem;margin:1rem 0;display:flex;gap:12px;align-items:flex-start;}
.ki-icon{font-size:22px;flex-shrink:0;margin-top:1px;}
.ki-text{font-size:14px;color:#14532d;line-height:1.6;}
.ki-text strong{font-weight:700;display:block;margin-bottom:3px;}
.ki-link{display:inline-flex;align-items:center;gap:5px;margin-top:8px;padding:7px 14px;background:#0d9488;color:white;text-decoration:none;border-radius:var(--radius-sm);font-size:13px;font-weight:700;}

/* MEBIS BOX */
.mebis-box{background:linear-gradient(135deg,#ede9fe,#ddd6fe);border:1.5px solid #a78bfa;border-radius:var(--radius-md);padding:1.1rem 1.25rem;margin:1rem 0;display:flex;gap:12px;align-items:flex-start;}
.mebis-icon{font-size:22px;flex-shrink:0;margin-top:1px;}
.mebis-text{font-size:14px;color:#3b0764;line-height:1.6;}
.mebis-text strong{font-weight:700;display:block;margin-bottom:3px;}
.mebis-link{display:inline-flex;align-items:center;gap:5px;margin-top:8px;padding:7px 14px;background:#7c3aed;color:white;text-decoration:none;border-radius:var(--radius-sm);font-size:13px;font-weight:700;}

/* QUIZ */
.quiz-wrap{margin:0.5rem 0;}
.quiz-q{font-size:15px;font-weight:600;color:var(--text);margin-bottom:0.75rem;line-height:1.5;}
.quiz-options{display:flex;flex-direction:column;gap:8px;margin-bottom:10px;}
.quiz-opt{display:flex;align-items:flex-start;gap:10px;padding:11px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:all 0.15s;background:white;font-size:14px;color:var(--text);line-height:1.4;text-align:left;font-family:'Nunito',sans-serif;width:100%;font-weight:500;}
.quiz-opt:hover{border-color:var(--blue-400);background:var(--blue-50);}
.quiz-opt.correct{border-color:var(--green);background:var(--green-light);color:#1b5e20;}
.quiz-opt.wrong{border-color:var(--red);background:var(--red-light);color:#7f1d1d;}
.quiz-opt.disabled{pointer-events:none;}
.quiz-opt-letter{width:22px;height:22px;border-radius:50%;background:var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0;margin-top:1px;color:var(--text-secondary);}
.quiz-opt.correct .quiz-opt-letter{background:var(--green);color:white;}
.quiz-opt.wrong .quiz-opt-letter{background:var(--red);color:white;}
.quiz-feedback{font-size:13px;padding:8px 12px;border-radius:var(--radius-sm);display:none;margin-top:6px;font-weight:500;}
.quiz-feedback.correct{background:var(--green-light);color:#1b5e20;display:block;}
.quiz-feedback.wrong{background:var(--red-light);color:#7f1d1d;display:block;}
.divider{border:none;border-top:1px solid var(--border);margin:1.25rem 0;}

/* NAV BTNS */
.nav-btns{display:flex;gap:10px;margin-top:1.5rem;justify-content:flex-end;flex-wrap:wrap;}
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--blue-700);color:white;border:none;border-radius:var(--radius-md);padding:11px 22px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all 0.15s;}
.btn-primary:hover{background:var(--blue-800);transform:translateY(-1px);}
.btn-secondary{display:inline-flex;align-items:center;gap:8px;background:white;color:var(--text);border:1.5px solid var(--border);border-radius:var(--radius-md);padding:11px 22px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.15s;}
.btn-secondary:hover{border-color:var(--blue-700);color:var(--blue-700);}

/* BADGE */
.badge-reveal{border-radius:var(--radius-lg);padding:2rem;text-align:center;margin-top:1.5rem;display:none;background:linear-gradient(135deg,#1e293b,#334155);}
.badge-reveal.visible{display:block;}
.badge-canvas-wrap{display:flex;justify-content:center;margin-bottom:1rem;}
.badge-name{font-family:'Nunito',sans-serif;font-size:20px;font-weight:900;color:white;margin-bottom:0.4rem;}
.badge-sub{font-size:14px;color:#94a3b8;margin-bottom:1.25rem;}
.badge-dl{display:inline-flex;align-items:center;gap:8px;background:var(--blue-700);color:white;border:none;border-radius:var(--radius-md);padding:10px 20px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;}
.badge-dl:hover{background:var(--blue-800);}

/* STEPS */
.step{display:none;}
.step.active{display:block;}
.teacher-only{display:none;}
body.version-b .teacher-only{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}

/* ABFRAGE */
.abfrage-wrap{display:flex;flex-direction:column;gap:1rem;}
.abfrage-q{border:1.5px solid var(--border);border-radius:var(--radius-md);overflow:hidden;}
.abfrage-q-header{padding:0.9rem 1.1rem;display:flex;align-items:center;gap:10px;background:#f8fafc;}
.abfrage-q-num{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:white;flex-shrink:0;}
.abfrage-q-num.wissen{background:var(--blue-700);}
.abfrage-q-num.denken{background:#0d9488;}
.abfrage-q-num.komm{background:var(--orange);}
.abfrage-q-num.kreativ{background:var(--red);}
.abfrage-q-meta{flex:1;}
.abfrage-q-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:2px;}
.abfrage-q-label.wissen{color:var(--blue-700);}
.abfrage-q-label.denken{color:#0d9488;}
.abfrage-q-label.komm{color:var(--orange);}
.abfrage-q-label.kreativ{color:var(--red);}
.abfrage-q-text{font-size:14px;font-weight:700;color:var(--text);line-height:1.4;}
.abfrage-q-body{padding:0.9rem 1.1rem;border-top:1px solid var(--border);background:white;}
.abfrage-q-body p{font-size:13px;color:var(--text-secondary);line-height:1.6;margin-bottom:0.5rem;}
.erwartung-btn{display:inline-flex;align-items:center;gap:5px;margin-top:8px;padding:6px 13px;border:1.5px solid var(--border);background:white;border-radius:var(--radius-sm);font-family:'Nunito',sans-serif;font-size:12px;font-weight:600;color:var(--text-secondary);cursor:pointer;transition:all 0.15s;}
.erwartung-btn:hover{border-color:var(--orange);color:var(--orange);background:var(--orange-light);}
.erwartung-box{margin-top:8px;background:var(--orange-light);border-left:3px solid var(--orange);border-radius:0 8px 8px 0;padding:10px 13px;font-size:13px;color:#78350f;line-height:1.6;display:none;}
.erwartung-box.visible{display:block;}
.print-btn{display:inline-flex;align-items:center;gap:7px;padding:10px 18px;background:white;border:1.5px solid var(--border);border-radius:var(--radius-md);font-family:'Nunito',sans-serif;font-size:13px;font-weight:600;color:var(--text-secondary);cursor:pointer;transition:all 0.15s;}
.print-btn:hover{border-color:var(--blue-700);color:var(--blue-700);}

/* PIN MODAL */
.pin-overlay{position:fixed;inset:0;background:rgba(15,23,42,0.7);backdrop-filter:blur(4px);z-index:999;display:none;align-items:center;justify-content:center;}
.pin-overlay.open{display:flex;}
.pin-box{background:white;border-radius:20px;padding:2rem 2rem 1.75rem;width:320px;box-shadow:0 24px 60px rgba(0,0,0,0.25);text-align:center;animation:fadeUp 0.2s ease both;}
.pin-logo{font-family:'Nunito',sans-serif;font-size:13px;font-weight:900;color:var(--blue-700);margin-bottom:1rem;}
.pin-logo span{color:var(--blue-400);}
