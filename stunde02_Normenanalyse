<script>
const TEACHER_PIN = '123456';
let pinInput='', cur=1, quizA={}, pollD={};
const TOTAL_STEPS = 6;

function openPinModal(){
  if(document.getElementById('body-root').classList.contains('version-b')){setVersion('a');return;}
  pinInput='';updatePinDots();
  document.getElementById('pin-error').textContent='';
  document.getElementById('pin-overlay').classList.add('open');
}
function closePinModal(){
  document.getElementById('pin-overlay').classList.remove('open');
  pinInput='';updatePinDots();
}
function pinKey(d){
  if(pinInput.length>=6)return;
  pinInput+=d;updatePinDots();
  if(pinInput.length===6)setTimeout(checkPin,120);
}
function pinDel(){
  pinInput=pinInput.slice(0,-1);updatePinDots();
  document.getElementById('pin-error').textContent='';
}
function updatePinDots(){
  for(let i=0;i<6;i++)document.getElementById('pd'+i).classList.toggle('filled',i<pinInput.length);
}
function checkPin(){
  if(pinInput===TEACHER_PIN){closePinModal();setVersion('b');}
  else{
    document.getElementById('pin-error').textContent='Falscher PIN – bitte nochmal versuchen.';
    pinInput='';updatePinDots();
    const box=document.querySelector('.pin-box');
    box.style.animation='none';
    setTimeout(()=>{box.style.animation='shake 0.35s ease';},10);
  }
}

function setVersion(v){
  const b=document.getElementById('body-root');
  document.getElementById('btn-a').classList.toggle('active',v==='a');
  document.getElementById('btn-b').classList.toggle('active',v==='b');
  if(v==='b'){
    b.classList.add('version-b');
    document.querySelectorAll('.teacher-only').forEach(e=>e.style.display='block');
    document.getElementById('btn-b').textContent='🎓 Lehrkraft ✓';
  } else {
    b.classList.remove('version-b');
    document.querySelectorAll('.teacher-only').forEach(e=>e.style.display='none');
    document.getElementById('btn-b').textContent='🎓 Lehrkraft';
    if(cur===6)goToStep(5);
  }
}

function goToStep(n){
  if(n===6&&!document.getElementById('body-root').classList.contains('version-b'))return;
  document.getElementById('step-'+cur).classList.remove('active');
  cur=n;
  document.getElementById('step-'+cur).classList.add('active');
  for(let i=1;i<=TOTAL_STEPS;i++){
    const s=document.getElementById('prog-'+i),l=document.getElementById('line-'+i);
    if(!s)continue;
    s.classList.remove('active','done');
    if(i<cur){s.classList.add('done');if(l)l.classList.add('done');}
    else if(i===cur){s.classList.add('active');if(l)l.classList.remove('done');}
    else if(l)l.classList.remove('done');
  }
  window.scrollTo({top:0,behavior:'smooth'});
}
function nextStep(f){if(f<TOTAL_STEPS)goToStep(f+1);}
function prevStep(f){if(f>1)goToStep(f-1);}

function revealSolution(id){
  const el=document.getElementById(id);el.classList.toggle('visible');
  el.previousElementSibling.textContent=el.classList.contains('visible')?'▲ Lösung ausblenden':'✓ Musterlösung anzeigen';
}
function toggleErwartung(id){
  const el=document.getElementById(id);el.classList.toggle('visible');
  el.previousElementSibling.textContent=el.classList.contains('visible')?'▲ Erwartungshorizont ausblenden':'📋 Erwartungshorizont anzeigen';
}

function checkQuiz(qId,btn,ok){
  const c=document.getElementById(qId);if(c.dataset.answered)return;
  c.dataset.answered='true';quizA[qId]=ok;
  c.querySelectorAll('.quiz-opt').forEach(b=>b.classList.add('disabled'));
  const fb=document.getElementById(qId+'-fb');
  const yes={
    q1:'✓ Richtig! Tatbestandsmerkmale sind die Voraussetzungen – das „Wenn" einer Rechtsnorm.',
    q2:'✓ Richtig! § 985 BGB gibt dem Eigentümer das Recht, die Herausgabe vom Besitzer zu verlangen.',
    q3:'✓ Richtig! BGB = Beziehung zwischen Privatpersonen · StGB = Staat schützt öffentliches Interesse.',
    q4:'✓ Richtig! § 903 BGB gibt dem Eigentümer das Recht, mit der Sache nach Belieben zu verfahren und andere auszuschließen.'
  };
  const no={
    q1:'✗ Nicht ganz. Ein Tatbestandsmerkmal ist eine Voraussetzung (das „Wenn"), keine Konsequenz. → B ist korrekt.',
    q2:'✗ Nicht ganz. § 985 BGB gibt den Herausgabeanspruch – Lena kann das Fahrrad zurückfordern. → B ist korrekt.',
    q3:'✗ Nicht ganz. Der Unterschied liegt in den Rechtsbereichen: BGB (privat) vs. StGB (öffentlich/staatlich). → C ist korrekt.',
    q4:'✗ Nicht ganz. § 903 BGB regelt die Befugnisse des Eigentümers: nach Belieben verfahren + andere ausschließen. → B ist korrekt.'
  };
  if(ok){btn.classList.add('correct');fb.textContent=yes[qId];fb.className='quiz-feedback correct';}
  else{btn.classList.add('wrong');fb.textContent=no[qId];fb.className='quiz-feedback wrong';}
  const qs=['q1','q2','q3','q4'];
  if(qs.every(q=>document.getElementById(q).dataset.answered)){
    document.getElementById('quiz-score').style.display='block';
    const n=qs.filter(q=>quizA[q]).length;
    document.getElementById('score-text').textContent=n+' von 4 Fragen richtig';
    document.getElementById('score-sub').textContent=n===4?' – Perfekt!':n>=3?' – Sehr gut!':' – Lies die Inhalte noch einmal durch.';
    if(n<3)document.getElementById('quiz-retry-wrap').style.display='block';
  }
}

function finishQuiz(){
  const qs=['q1','q2','q3','q4'],n=qs.filter(q=>quizA[q]).length;
  if(n>=3){document.getElementById('badge-1').classList.add('visible');drawBadge();}
  else{
    document.getElementById('quiz-score').style.display='block';
    document.getElementById('score-text').textContent=n+' von 4 Fragen richtig';
    document.getElementById('score-sub').textContent=' – Lies die Inhalte noch einmal durch und versuche es erneut.';
    document.getElementById('quiz-retry-wrap').style.display='block';
  }
}

function retryQuiz(){
  const qs=['q1','q2','q3','q4'];
  qs.forEach(q=>{
    const c=document.getElementById(q);delete c.dataset.answered;
    c.querySelectorAll('.quiz-opt').forEach(b=>b.classList.remove('disabled','correct','wrong'));
    document.getElementById(q+'-fb').className='quiz-feedback';
    document.getElementById(q+'-fb').textContent='';
  });
  quizA={};
  document.getElementById('quiz-score').style.display='none';
  document.getElementById('quiz-retry-wrap').style.display='none';
  window.scrollTo({top:document.getElementById('step-5').offsetTop-60,behavior:'smooth'});
}

function drawBadge(){
  const cv=document.getElementById('badge-canvas'),ctx=cv.getContext('2d');
  const w=280,h=280,cx=140,cy=140,r=128;
  const g=ctx.createRadialGradient(cx,cy-30,20,cx,cy,r);
  g.addColorStop(0,'#1976D2');g.addColorStop(1,'#0D47A1');
  ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();
  ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.strokeStyle='#fbbf24';ctx.lineWidth=6;ctx.stroke();
  ctx.beginPath();ctx.arc(cx,cy,r-12,0,Math.PI*2);ctx.strokeStyle='rgba(251,191,36,0.2)';ctx.lineWidth=2;ctx.stroke();
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(cx,cy-60);ctx.bezierCurveTo(cx+52,cy-60,cx+62,cy-18,cx+62,cy+14);
  ctx.bezierCurveTo(cx+62,cy+48,cx+24,cy+72,cx,cy+80);
  ctx.bezierCurveTo(cx-24,cy+72,cx-62,cy+48,cx-62,cy+14);
  ctx.bezierCurveTo(cx-62,cy-18,cx-52,cy-60,cx,cy-60);
  ctx.closePath();ctx.fillStyle='rgba(255,255,255,0.1)';ctx.fill();ctx.strokeStyle='#fbbf24';ctx.lineWidth=3;ctx.stroke();
  ctx.restore();
  ctx.font='bold 56px Georgia,serif';ctx.fillStyle='#fbbf24';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('§',cx,cy-4);
  ctx.font='bold 17px sans-serif';ctx.fillStyle='#ffffff';ctx.textAlign='center';ctx.textBaseline='alphabetic';
  ctx.fillText('RECHTS-',cx,cy+58);ctx.fillText('EINSTEIGER',cx,cy+79);
  ctx.font='14px sans-serif';ctx.fillStyle='#fbbf24';ctx.textBaseline='middle';
  ctx.fillText('★',cx-72,cy+26);ctx.fillText('★',cx+72,cy+26);
  ctx.font='10px sans-serif';ctx.fillStyle='rgba(255,255,255,0.4)';ctx.textBaseline='alphabetic';
  ctx.fillText('WR 10 · Lernbereich 2 · Modul 1',cx,cy+104);
  document.getElementById('badge-dl').href=cv.toDataURL('image/png');
}

document.getElementById('pin-overlay').addEventListener('click',function(e){if(e.target===this)closePinModal();});
document.addEventListener('keydown',function(e){
  if(!document.getElementById('pin-overlay').classList.contains('open'))return;
  if(e.key>='0'&&e.key<='9')pinKey(e.key);
  else if(e.key==='Backspace')pinDel();
  else if(e.key==='Escape')closePinModal();
});
</script>
